# Telegram API credentials — get these from https://my.telegram.org/apps
API_ID=your_api_id
API_HASH=your_api_hash

# Your Telegram phone number (international format)
PHONE_NUMBER=+1234567890

# Session string — generate once locally by running: python generate_session.py
# Required for Docker / cloud deployments
SESSION_STRING=

# Source channel to monitor (public username or numeric ID)
# Examples: @somechannel  or  -1001234567890
SOURCE_CHANNEL=@source_channel

# Target channel to forward files into (you must be an admin there)
# Examples: @mychannel  or  -1009876543210
TARGET_CHANNEL=@target_channel
